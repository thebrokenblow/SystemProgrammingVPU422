<Window
    x:Class="Lesson5.Desktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Lesson5.Desktop"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="800"
    Height="450"
    mc:Ignorable="d">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Height="30" Orientation="Horizontal">
                <Label Content="Результат: " />
                <TextBlock Name="Result" Width="150" />
            </StackPanel>

            <StackPanel Height="30" Orientation="Horizontal">
                <Label Content="Введите число: " />
                <TextBox Name="Number" Width="150" />
            </StackPanel>

            <Button
                Name="SumButton"
                Click="SumButton_Click"
                Content="Посчитать" />

            <Button
                Name="CancellationSumButton"
                Click="CancellationSumButton_Click"
                Content="Отменить"
                IsEnabled="False" />
        </StackPanel>
    </Grid>
</Window>
